# OpenRouter (Free-Modell fuer Recherche)
OPENROUTER_API_KEY=sk-or-v1-DEIN_KEY_HIER

# Anthropic Claude (Paid, fuer tiefe Analyse und Kreatives)
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER

# Free-Modell: wird aus .env geladen, Fallback im Code: openrouter/auto
# Optionen: openrouter/auto  (lässt OpenRouter das beste Free-Modell waehlen)
#           arcee-ai/trinity-large-preview:free
OPENROUTER_MODEL=openrouter/auto

# Claude-Modell (optional, Standard: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514
